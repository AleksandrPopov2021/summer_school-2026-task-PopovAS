# HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# PostgreSQL (matches docker-compose defaults)
DATABASE_URL=postgres://vertical:vertical@localhost:5432/vertical?sslmode=disable

# CORS — comma-separated origins for mobile dev
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT (used from iteration 1)
JWT_SECRET=change-me-in-production

# Internal API key (iteration 6 — gym cancel, dev/staging)
INTERNAL_API_KEY=dev-internal-key

# Push notifications (iteration 7): logging | noop | fcm (not implemented)
PUSH_SENDER=logging

# Background worker tick interval
WORKER_INTERVAL=1m
